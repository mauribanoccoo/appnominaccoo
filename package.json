{
  "name": "Nominaccoo",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "node server.ts",
    "gcp-build": "npm run build",
    "dev": "PORT=3001 npx -y tsx server.ts & ng serve --host 0.0.0.0 --port 3000 --proxy-config proxy.conf.json",
    "build": "npx ng build --configuration development --no-optimization --no-source-map --no-progress",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint"
  },
  "private": true,
  "engines": {
    "node": ">=18.13.0"
  },
  "dependencies": {
    "@angular/animations": "21.2.1",
    "@angular/common": "21.2.1",
    "@angular/compiler": "21.2.1",
    "@angular/core": "21.2.1",
    "@angular/forms": "21.2.1",
    "@angular/material": "21.2.1",
    "@angular/platform-browser": "21.2.1",
    "@angular/platform-browser-dynamic": "21.2.1",
    "@angular/router": "21.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/cors": "^2.8.19",
    "@types/d3": "^7.4.3",
    "@types/express": "^5.0.6",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "express": "^5.2.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "motion": "^12.35.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.2.0",
    "@angular-eslint/schematics": "^21.2.0",
    "@angular/build": "21.2.1",
    "@angular/cli": "21.2.1",
    "@angular/compiler-cli": "21.2.1",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
